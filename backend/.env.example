MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=finance_rag
MONGODB_DOCUMENTS_COLLECTION=documents
MONGODB_USERS_COLLECTION=users
MONGODB_SESSIONS_COLLECTION=auth_sessions
DOCUMENTS_STORAGE_DIR=storage/documents

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=ministere_docs
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-0.6B
OLLAMA_BASE_URL=http://localhost:11434
GENERATION_MODEL_NAME=llama3:latest

AUTH_MODE=local
AUTH_SESSION_COOKIE_NAME=rag_finance_session
AUTH_CSRF_COOKIE_NAME=rag_finance_csrf
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_SESSION_IDLE_MINUTES=30
AUTH_SESSION_ABSOLUTE_HOURS=8
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_HOURS=8
AUTH_FRONTEND_BASE_URL=http://localhost:5173
AUTH_OIDC_ISSUER_URL=http://localhost:8080/realms/rag-finance
AUTH_OIDC_CLIENT_ID=rag-finance-web
AUTH_OIDC_CLIENT_SECRET=change-me
AUTH_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
AUTH_OIDC_SCOPE=openid profile email

AUTH_SEED_DEFAULT_USERS=true
AUTH_DEFAULT_ADMIN_EMAIL=admin@finance.local
AUTH_DEFAULT_ADMIN_PASSWORD=Admin123!
AUTH_DEFAULT_USER_EMAIL=user@finance.local
AUTH_DEFAULT_USER_PASSWORD=User123!

